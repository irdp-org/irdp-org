# ===== IRDP — .env.local.example =====
# คัดลอกเป็น .env.local แล้วเติมค่า ; ห้าม commit .env.local จริง
# ค่าที่ไม่มี NEXT_PUBLIC_ = server-only (ห้ามหลุดไป client)

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://wkeiblrdmspmttmlfugs.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_2fWSF7VWS9w7yfYI90kLyw_a8yT1WL-
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY        # server-only

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Web Push (VAPID) ---  สร้างด้วย: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY               # server-only
VAPID_SUBJECT=mailto:info@irdp.org

# --- Cron protection ---
CRON_SECRET=GENERATE_A_LONG_RANDOM_STRING              # server-only

# --- Google Calendar (two-way sync) --- server-only
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALENDAR_ID=org_calendar_id@group.calendar.google.com
# ใช้ refresh token ของบัญชีองค์กร หรือ service account อย่างใดอย่างหนึ่ง
GOOGLE_CALENDAR_REFRESH_TOKEN=
# GOOGLE_SERVICE_ACCOUNT_JSON=
